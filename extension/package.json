{
  "name": "x-posed-extension",
  "version": "2.6.0",
  "description": "See where X users are located and what devices they use. Country flags & device icons next to every username. Optional geo-blocking.",
  "type": "module",
  "scripts": {
    "dev": "rollup -c -w",
    "dev:chrome": "cross-env BROWSER=chrome rollup -c -w",
    "dev:firefox": "cross-env BROWSER=firefox rollup -c -w",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "cross-env BROWSER=chrome rollup -c",
    "build:firefox": "cross-env BROWSER=firefox rollup -c",
    "build:prod": "cross-env NODE_ENV=production npm run build",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "package:chrome": "npm run build:chrome && node scripts/zip.js chrome",
    "package:firefox": "npm run build:firefox && node scripts/zip.js firefox",
    "package": "npm run package:chrome && npm run package:firefox",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{js,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "archiver": "^7.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.9.6",
    "rollup-plugin-copy": "^3.5.0"
  },
  "keywords": [
    "x",
    "twitter",
    "extension",
    "chrome",
    "firefox",
    "location",
    "device"
  ],
  "author": "xaitax",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xaitax/x-account-location-device"
  },
  "bugs": {
    "url": "https://github.com/xaitax/x-account-location-device/issues"
  },
  "homepage": "https://github.com/xaitax/x-account-location-device#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
